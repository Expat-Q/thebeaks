{
  "builds": [
    { "src": "api/leaderboard.js", "use": "@vercel/node" },
    { "src": "api/ping.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ping", "dest": "/api/ping.js" },
    { "src": "/api/leaderboard", "dest": "/api/leaderboard.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
